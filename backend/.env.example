# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/logal-prime?retryWrites=true&w=majority

# JWT secret key - change this to a long random string
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro_2024

# JWT expiration
JWT_EXPIRES=7d

# Port (Render.com assigns this automatically)
PORT=5000

# Frontend URL (for CORS - set to your Render frontend URL after deploy)
FRONTEND_URL=https://logal-prime.onrender.com
